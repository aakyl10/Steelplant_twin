        {
          "datasource": {
            "type": "influxdb",
            "uid": "steelplant-influxdb"
          },
          "query": "from(bucket: \"telemetry\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r._measurement == \"compressed_air_telemetry\")\r\n  |> filter(fn: (r) => r._field == \"SEC\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\r\n  |> yield(name: \"SEC\")",
          "refId": "Specific Energy Consumption"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "steelplant-influxdb"
          },
          "hide": false,
          "query": "from(bucket: \"telemetry\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r._measurement == \"compressed_air_telemetry\")\r\n  |> filter(fn: (r) => r._field == \"compressed_air_demand\" or r._field == \"total_airflow\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\r\n  |> yield(name: \"Demand and airflow\")",
          "refId": "Compressed Air Demand and Total Airflow"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "steelplant-influxdb"
          },
          "hide": false,
          "query": "from(bucket: \"telemetry\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r._measurement == \"compressed_air_telemetry\")\r\n  |> filter(fn: (r) => r._field == \"pressure_deviation\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\r\n  |> yield(name: \"Pressure deviation\")",
          "refId": "Pressure Deviation"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "steelplant-influxdb"
          },
          "hide": false,
          "query": "from(bucket: \"telemetry\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r._measurement == \"compressed_air_telemetry\")\r\n  |> filter(fn: (r) => r._field == \"active_compressors_count\" or r._field == \"compressor_2_load_level\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\r\n  |> yield(name: \"Compressor operation\")",
          "refId": "Compressor Operation"
        }
